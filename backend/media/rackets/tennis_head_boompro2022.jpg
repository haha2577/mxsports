                    display: flex;
                    flex-direction: column;
                    justify-content: center;
                    align-items: center;
                    text-align: center;
                }

                .fallback-nojs a {
                    color: currentColor;
                }

                .fallback-closed {
                    height: 40vh;
                }

                .fallback-heading {
                    font-family: 'Source Serif Pro';
                    font-weight: 600;
                    padding-bottom: 16px;
                    font-size: xx-large;
                }

                .fallback-message {
                    font-family: 'Muli';
                }

                @media only screen and (max-width: 768px) {
                    .fallback-heading {
                        font-size: x-large;
                    }
                }</style></noscript><script>if (
