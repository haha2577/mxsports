.ls-wrap{position:fixed;top:0;left:0;right:0;bottom:0;z-index:998}
.ls-mask{position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5)}
.ls-sheet{position:absolute;bottom:0;left:0;right:0;background:#fff;border-radius:32rpx 32rpx 0 0;padding:24rpx 48rpx 60rpx}
.ls-handle{width:60rpx;height:8rpx;background:#e0e0e0;border-radius:4rpx;margin:0 auto 36rpx}
.ls-title{display:block;font-size:40rpx;font-weight:bold;color:#1a1a1a;margin-bottom:8rpx}
.ls-sub{display:block;font-size:26rpx;color:#aaa;margin-bottom:48rpx}
.ls-btn{display:flex;align-items:center;justify-content:center;gap:16rpx;height:96rpx;border-radius:50rpx;margin-bottom:20rpx}
.ls-wechat{background:#07c160}.ls-sms{background:#f5f5f5}.ls-confirm{background:#1a1a2e}
.ls-disabled{opacity:.4}
.ls-btn-icon{font-size:36rpx}
.ls-wechat .ls-btn-txt,.ls-confirm .ls-btn-txt{font-size:32rpx;font-weight:600;color:#fff}
.ls-sms .ls-btn-txt{font-size:32rpx;font-weight:600;color:#1a1a1a}
.ls-agree{display:block;text-align:center;font-size:22rpx;color:#bbb;margin-top:24rpx}
.ls-back{font-size:28rpx;color:#888;margin-bottom:24rpx;display:block}
.ls-input-wrap{display:flex;align-items:center;border:2rpx solid #e8e8e8;border-radius:16rpx;padding:0 24rpx;height:96rpx;margin-bottom:20rpx}
.ls-prefix{font-size:30rpx;color:#333;font-weight:500;margin-right:16rpx;border-right:2rpx solid #e8e8e8;padding-right:16rpx}
.ls-input{flex:1;font-size:30rpx;color:#1a1a1a}
.ls-sms-btn{font-size:26rpx;color:#1a1a2e;font-weight:600;white-space:nowrap;padding-left:16rpx}
.ls-sms-cd{color:#bbb}
.ls-error{display:block;font-size:22rpx;color:#e53935;background:#fff0f0;border-radius:12rpx;padding:16rpx 20rpx;margin-bottom:16rpx;word-break:break-all}

/* 完善资料 */
.ls-profile-avatar{display:flex;justify-content:center;margin-bottom:32rpx}
.ls-avatar-btn{padding:0;margin:0;background:none;border:none;width:160rpx;height:160rpx;line-height:normal;font-size:0}
.ls-avatar-btn::after{display:none}
.ls-avatar-img{width:160rpx;height:160rpx;border-radius:50%}
.ls-avatar-empty{width:160rpx;height:160rpx;border-radius:50%;background:#f0f2f5;display:flex;flex-direction:column;align-items:center;justify-content:center}
.ls-avatar-plus{font-size:48rpx}
.ls-avatar-hint{font-size:20rpx;color:#aaa;margin-top:4rpx}
.ls-skip{display:block;text-align:center;font-size:26rpx;color:#aaa;margin-top:16rpx}