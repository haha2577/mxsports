.nav-bar{width:100%;position:relative;z-index:100}
.nav-content{display:flex;align-items:center;padding:0 16rpx;position:relative}
.back-btn{width:56rpx;height:56rpx;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-left:8rpx}
.back-icon{width:44rpx;height:44rpx;display:block}
.back-placeholder{width:56rpx;height:56rpx;flex-shrink:0;margin-left:8rpx}
.nav-title{position:absolute;left:50%;transform:translateX(-50%);font-size:32rpx;color:#fff;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:60%}
