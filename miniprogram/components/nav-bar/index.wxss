.nav-bar{width:100%;position:relative;z-index:100}
.nav-content{display:flex;align-items:center;padding:0 16rpx}
.back-btn{width:72rpx;height:72rpx;display:flex;align-items:center;justify-content:center;border-radius:50%;background:rgba(255,255,255,.15);flex-shrink:0;margin-left:8rpx}
.back-icon{font-size:44rpx;color:#fff;font-weight:bold;line-height:1;margin-top:-4rpx}
.back-placeholder{width:72rpx;height:72rpx;flex-shrink:0;margin-left:8rpx}
.nav-title{font-size:32rpx;color:#fff;font-weight:600;margin-left:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
