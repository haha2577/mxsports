<view wx:if="{{canSwitch}}" class="sport-switcher">
  <view class="ss-tab {{active==='badminton'?'ss-active':''}}" bindtap="onBadminton">
    <view class="ss-dot ss-dot-b"/><text class="ss-label">羽毛球</text>
  </view>
  <view class="ss-tab {{active==='tennis'?'ss-active':''}}" bindtap="onTennis">
    <view class="ss-dot ss-dot-t"/><text class="ss-label">网球</text>
  </view>
</view>