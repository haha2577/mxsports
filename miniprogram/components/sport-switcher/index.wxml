<view wx:if="{{sportPref === 'both'}}" class="sport-switcher">
  <view class="ss-tab {{active==='badminton'?'ss-active':''}}" bindtap="onBadminton">
    <text class="ss-emoji">🏸</text><text class="ss-label">羽毛球</text>
  </view>
  <view class="ss-tab {{active==='tennis'?'ss-active':''}}" bindtap="onTennis">
    <text class="ss-emoji">🎾</text><text class="ss-label">网球</text>
  </view>
</view>