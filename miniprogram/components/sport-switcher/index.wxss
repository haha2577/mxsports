.sport-switcher{display:flex;background:rgba(255,255,255,.15);border:1rpx solid rgba(255,255,255,.2);border-radius:50rpx;padding:4rpx;gap:4rpx}
.ss-tab{display:flex;align-items:center;gap:8rpx;padding:10rpx 22rpx;border-radius:50rpx}
.ss-active{background:rgba(255,255,255,.9)}
.ss-active .ss-label{color:#1a1a2e;font-weight:bold}
.ss-dot{width:16rpx;height:16rpx;border-radius:50%;flex-shrink:0}.ss-dot-b{background:#1DB954}.ss-dot-t{background:#d4541f}.ss-label{font-size:22rpx;color:rgba(255,255,255,.9)}