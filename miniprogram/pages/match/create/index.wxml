<view class="page">
  <view class="page-header" style="background:{{heroGrad}}">
    <nav-bar background="{{heroGrad}}" title="创建活动"/>
    <view class="hd-body">
      <text class="hd-sub">填写信息，邀请好友一起打球</text>
    </view>
  </view>
  <scroll-view class="page-body" scroll-y enable-passive>
    <view class="form">
      <view class="field">
        <text class="field-label">活动名称 <text class="req">*</text></text>
        <input class="field-input" value="{{name}}" bindinput="onName" placeholder="例如：周末双打约战" maxlength="30"/>
      </view>
      <view class="field-row">
        <view class="field field-half">
          <text class="field-label">日期 <text class="req">*</text></text>
          <picker mode="multiSelector" value="{{dateIndex}}" range="{{dateColumns}}" bindchange="onDateChange" bindcolumnchange="onDateColumnChange">
            <view class="field-picker"><text class="{{date?'picker-val':'picker-ph'}}">{{dateDisplay||'选择日期'}}</text><text class="picker-arrow">›</text></view>
          </picker>
        </view>
        <view class="field field-half">
          <text class="field-label">时间</text>
          <picker mode="multiSelector" value="{{timeIndex}}" range="{{timeColumns}}" bindchange="onTimeChange">
            <view class="field-picker"><text class="picker-val">{{timeDisplay}}</text><text class="picker-arrow">›</text></view>
          </picker>
        </view>
      </view>
      <view class="field">
        <text class="field-label">活动地点 <text class="req">*</text></text>
        <view class="field-picker loc-picker" bindtap="pickLocation">
          <view class="loc-left"><svg-icon name="map-pin" size="32" color="#999"/><text class="{{location?'picker-val':'picker-ph'}}">{{locationName||location||'搜索地点'}}</text></view>
          <view style="display:flex;align-items:center;gap:8rpx">
            <text wx:if="{{location}}" class="loc-clear" catchtap="clearLocation">✕</text>
            <text class="picker-arrow">›</text>
          </view>
        </view>
        <text wx:if="{{locationAddr}}" class="loc-addr">{{locationAddr}}</text>
      </view>
      <view class="field">
        <text class="field-label">人数上限</text>
        <view class="tag-row">
          <view wx:for="{{maxOptions}}" wx:key="*this" class="tag {{maxPlayers===item?'tag-a':''}}" bindtap="setMax" data-v="{{item}}">{{item}}人</view>
          <view class="tag {{maxCustom?'tag-a':''}}" bindtap="setMaxCustom">自定义</view>
        </view>
        <view wx:if="{{maxCustom}}" class="custom-max-row">
          <input class="custom-max-input" type="number" value="{{maxCustomVal}}" bindinput="onMaxCustomInput" placeholder="输入人数" maxlength="3"/>
          <text class="custom-max-unit">人</text>
        </view>
      </view>
      <view class="field">
        <text class="field-label">水平要求</text>
        <view class="tag-row">
          <view wx:for="{{levelOptions}}" wx:key="*this" class="tag {{level===item||(!level&&item==='不限')?'tag-a':''}}" bindtap="setLevel" data-v="{{item}}">{{item}}</view>
        </view>
      </view>
      <view class="field">
        <text class="field-label">报名费用</text>
        <view class="field-fee-wrap"><text class="fee-prefix">¥</text><input class="field-input field-fee" value="{{fee}}" bindinput="onFee" type="digit" placeholder="0（免费）" maxlength="6"/></view>
      </view>
    </view>
    <view class="submit-btn {{loading?'submit-loading':''}}" bindtap="submit">
      <text>{{loading?'创建中...':'确认创建'}}</text>
    </view>
  </scroll-view>

  <view wx:if="{{showSuccess}}" class="success-mask" bindtap="closeSuccess">
    <view class="success-card" catchtap="">
      <view class="sc-close" bindtap="closeSuccess">✕</view>
      <svg-icon name="sparkles" size="80" color="#f59e0b"/>
      <text class="sc-title">活动创建成功！</text>
      <text class="sc-sub">分享给好友，邀请他们一起来参加</text>
      <button class="sc-share-btn" open-type="share">分享给好友</button>
      <view class="sc-detail-btn" bindtap="goDetail">查看活动详情 ›</view>
    </view>
    <view class="safe-bottom"/>
  </view>
</view>
