.page{background:#f0f2f5}

/* header */
.page-header{padding:0}
.sport-tabs{width:100%;display:flex;gap:12rpx;margin-top:8rpx}
.stab{flex:1;text-align:center;padding:14rpx 0;border-radius:50rpx;font-size:26rpx;color:rgba(255,255,255,.5);background:rgba(255,255,255,.08)}
.stab-a{background:rgba(255,255,255,.18);color:#fff;font-weight:bold}

/* form */
.form{margin:24rpx 24rpx 0;background:#fff;border-radius:24rpx;padding:0 28rpx 8rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.05)}
.field{padding:28rpx 0;border-bottom:1rpx solid #f5f5f5}
.field:last-child{border-bottom:none}
.field-row{display:flex;gap:16rpx;padding:28rpx 0;border-bottom:1rpx solid #f5f5f5}
.field-half{flex:1;padding:0}
.field-label{display:block;font-size:26rpx;font-weight:600;color:#333;margin-bottom:16rpx}
.req{color:#f44}
.field-input{background:#f8f8f8;border-radius:16rpx;padding:24rpx;font-size:28rpx;color:#1a1a1a;width:100%;box-sizing:border-box;height:88rpx;line-height:40rpx}
.field-picker{background:#f8f8f8;border-radius:16rpx;padding:24rpx;display:flex;align-items:center;justify-content:space-between;box-sizing:border-box}
.picker-val{font-size:28rpx;color:#1a1a1a}
.picker-ph{font-size:28rpx;color:#bbb}
.picker-arrow{font-size:32rpx;color:#ccc}
.loc-input-wrap{display:flex;align-items:center;gap:12rpx;background:#f8f8f8;border-radius:16rpx;padding:0 24rpx;height:88rpx}
.loc-text-input{flex:1;font-size:28rpx;color:#1a1a1a;height:88rpx;line-height:88rpx}
.loc-map-btn{width:56rpx;height:56rpx;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.field-fee-wrap{display:flex;align-items:center;background:#f8f8f8;border-radius:16rpx;padding:0 24rpx;height:88rpx}
.fee-prefix{font-size:32rpx;color:#888;margin-right:8rpx}
.field-fee{flex:1;font-size:28rpx;color:#1a1a1a;height:88rpx;line-height:88rpx}

/* 标签选择 */
.tag-row{display:flex;flex-wrap:wrap;gap:12rpx}
.tag{padding:14rpx 28rpx;border-radius:50rpx;font-size:26rpx;color:#666;background:#f5f5f5}
.tag-a{background:#1a1a2e;color:#fff}

/* 自定义人数 */
.custom-max-row{display:flex;align-items:center;margin-top:16rpx;background:#f8f8f8;border-radius:16rpx;padding:0 24rpx;height:88rpx;width:240rpx}
.custom-max-input{flex:1;font-size:32rpx;color:#1a1a1a;font-weight:bold}
.custom-max-unit{font-size:28rpx;color:#888;margin-left:8rpx}

/* 提交按钮 */
.submit-btn{margin:24rpx 24rpx 0;background:linear-gradient(135deg,#1a1a2e,#0f3460);border-radius:24rpx;height:100rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 24rpx rgba(15,52,96,.35)}
.submit-btn text{font-size:32rpx;font-weight:bold;color:#fff}
.submit-loading{opacity:.6}

/* 成功弹窗 */
.success-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;z-index:999}
.success-card{position:relative;background:#fff;border-radius:28rpx;padding:52rpx 40rpx 44rpx;margin:0 48rpx;width:calc(100% - 96rpx);box-sizing:border-box;display:flex;flex-direction:column;align-items:center;gap:10rpx}
.sc-close{position:absolute;top:20rpx;right:24rpx;width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center;font-size:26rpx;color:#bbb;border-radius:50%}
.sc-title{font-size:36rpx;font-weight:bold;color:#1a1a1a;margin-top:8rpx}
.sc-sub{font-size:25rpx;color:#aaa}
.sc-btns{width:100%;display:flex;flex-direction:column;gap:16rpx;margin-top:28rpx}
.sc-share-btn{width:100%;background:linear-gradient(135deg,#1DB954,#17a347);color:#fff;border:none;border-radius:18rpx;height:88rpx;line-height:88rpx;font-size:30rpx;font-weight:700;box-sizing:border-box;letter-spacing:2rpx;padding:0}
.sc-detail-btn{width:100%;height:88rpx;background:#f5f5f5;border-radius:18rpx;display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#555;font-weight:500;box-sizing:border-box}
