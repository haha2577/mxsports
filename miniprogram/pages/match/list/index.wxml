<view class="page">
  <view class="page-header" style="background:{{heroGrad}}">
    <nav-bar background="{{heroGrad}}" title="附近的约球"/>
    <view class="hd-body">
      <text class="hd-sub">找到附近合适的活动，马上报名</text>
    </view>
    <view class="search-bar">
      <svg-icon name="search" size="32" color="rgba(255,255,255,0.7)"/>
      <input class="si-input" value="{{keyword}}" bindinput="onKeyword" placeholder="搜索地点、活动名称"/>
    </view>
    <scroll-view scroll-x class="filter-scroll">
      <view class="filter-row">
        <view class="chip {{filterLevel?'chip-a':''}}" bindtap="openLevel">{{filterLevel||'水平'}} ▾</view>
        <view class="chip {{filterFee?'chip-a':''}}" bindtap="openFee">{{feeLabel||'费用'}} ▾</view>
        <view wx:if="{{hasFilter}}" class="chip chip-reset" bindtap="resetAll">✕ 清除</view>
      </view>
    </scroll-view>
  </view>
  <scroll-view class="page-body" scroll-y enable-passive>
    <view class="result-bar">
      <text class="rt">共 {{list.length}} 个约球</text>
    </view>
    <view wx:if="{{!list.length}}" class="empty">
      <svg-icon name="award" size="80" color="#ddd"/>
      <text class="et">附近暂无约球活动</text>
    </view>
    <view wx:else class="list">
      <view wx:for="{{list}}" wx:key="id" class="match-card" bindtap="goDetail" data-id="{{item.id}}">
        <view class="mc-top">
          <view class="sport-tag {{item.sport==='badminton'?'tag-b':'tag-t'}}">{{item.sport==='badminton'?'羽毛球':'网球'}}</view>
          <text class="status-dot s-{{item.status}}">{{item.status==='open'?'报名中':item.status==='full'?'已满员':'已结束'}}</text>
        </view>
        <text class="mc-title">{{item.name}}</text>
        <view class="mc-info icon-row"><svg-icon name="map-pin" size="24" color="#999"/><text>{{item.location}}</text><text class="mc-sep"> · </text><svg-icon name="ruler" size="24" color="#999"/><text>{{item.distance}}</text></view>
        <view class="mc-info icon-row"><svg-icon name="calendar" size="24" color="#999"/><text>{{item.date}}</text><text class="mc-sep"> · </text><svg-icon name="clock" size="24" color="#999"/><text>{{item.time}}</text></view>
        <view class="mc-tags">
          <view class="mt-tag level-tag icon-row"><svg-icon name="star" size="22" color="#f57c00"/>{{item.level}}</view>
          <view class="mt-tag people-tag icon-row"><svg-icon name="users" size="22" color="#1565c0"/>{{item.joined}}/{{item.maxPlayers}}人</view>
          <view class="mt-tag fee-tag icon-row"><svg-icon name="banknote" size="22" color="#7b1fa2"/>{{item.fee>0?item.fee+'元/人':'免费'}}</view>
        </view>
        <view class="mc-footer">
          <text class="org">{{item.organizer}} 发起</text>
          <view class="join-btn {{item.status!=='open'?'join-dis':''}}">{{item.status==='open'?'报名参加':'已截止'}}</view>
        </view>
      </view>
    </view>
    <view class="fab" bindtap="goCreate"><text class="fab-t">＋ 发起约球</text></view>
    <view class="safe-bottom"/>
  </scroll-view>
</view>
