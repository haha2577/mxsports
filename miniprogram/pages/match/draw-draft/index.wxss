.page{background:#f0f2f5;height:100vh;display:flex;flex-direction:column;overflow:hidden}

/* 顶部 */
.page-header{padding:32rpx 32rpx 20rpx;flex-shrink:0}
.page-body{flex:1;overflow:hidden;padding-bottom:160rpx}

/* 总场数调节器 */
.round-ctrl{flex-shrink:0;display:flex;align-items:center;padding:18rpx 32rpx;background:#fff;box-shadow:0 2rpx 8rpx rgba(0,0,0,.06)}
.rc-left{flex:1}
.rc-total{font-size:24rpx;color:#aaa}
.rc-center{display:flex;align-items:center;gap:20rpx}
.rc-btn{width:64rpx;height:64rpx;display:flex;align-items:center;justify-content:center;background:#f0f2f5;border-radius:50%;font-size:36rpx;color:#333;line-height:1}
.rc-btn-dis{opacity:.3}
.rc-num{font-size:48rpx;font-weight:700;color:#1a1a1a;min-width:56rpx;text-align:center;line-height:1}
.rc-unit{font-size:26rpx;color:#888}
.rc-right{flex:1;display:flex;justify-content:flex-end}
.rc-per{font-size:24rpx;color:#aaa;background:#f5f5f5;padding:8rpx 18rpx;border-radius:50rpx}
.hd-top{display:flex;align-items:center;gap:16rpx;margin-bottom:8rpx}
.hd-title{font-size:32rpx;font-weight:bold;color:#fff;flex:1}
.hd-badge{font-size:22rpx;color:#fff;background:rgba(255,255,255,.15);padding:6rpx 16rpx;border-radius:50rpx}
.hd-sub{font-size:22rpx;color:rgba(255,255,255,.5)}


/* 场次列表 */
.games-list{padding:16rpx 24rpx 0}
.game-card{background:#fff;border-radius:24rpx;padding:24rpx;margin-bottom:16rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.05)}
.game-no{margin-bottom:16rpx}
.game-no text{font-size:22rpx;color:#aaa}
.game-body{display:flex;align-items:center;gap:12rpx}
.team{flex:1;display:flex;flex-direction:column;gap:10rpx}
.vs-badge{width:56rpx;height:56rpx;background:#f0f2f5;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.vs-badge text{font-size:22rpx;color:#aaa;font-weight:bold}
.player-chip{padding:16rpx 20rpx;border-radius:16rpx;text-align:center}
.chip-filled{background:#e8f7ee}
.chip-filled text{font-size:28rpx;color:#0a7a38;font-weight:bold}
.chip-empty{background:#f5f5f5}
.chip-empty text{font-size:26rpx;color:#ccc}

/* 底部按钮 */
.bottom-bar{position:fixed;bottom:0;left:0;right:0;background:#fff;padding:24rpx 24rpx 48rpx;display:flex;gap:16rpx;box-shadow:0 -4rpx 16rpx rgba(0,0,0,.07)}
.reshuffle-btn{flex:1;height:88rpx;background:#f5f5f5;border-radius:24rpx;display:flex;align-items:center;justify-content:center}
.reshuffle-btn text{font-size:28rpx;color:#555}
.confirm-btn{flex:2;height:88rpx;background:linear-gradient(135deg,#1a1a2e,#0f3460);border-radius:24rpx;display:flex;align-items:center;justify-content:center}
.confirm-btn text{font-size:30rpx;font-weight:bold;color:#fff}
.confirm-loading{opacity:.6}
