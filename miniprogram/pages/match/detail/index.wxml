<view class="page">

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <text class="loading-txt">加载中...</text>
  </view>

  <block wx:elif="{{match}}">

  <!-- 固定顶部 -->
  <view class="page-top" id="page-top">

    <view class="hero" style="background:{{heroGrad}}">
      <nav-bar
        title="比赛详情"
        background="{{heroGrad}}"/>
      <text class="hero-deco">{{sportEmoji}}</text>
      <view class="hd-body hero-inner">
        <text class="hero-name">{{match.name}}</text>
        <view class="hero-top">
          <view class="status-badge status-{{match.status}}">{{statusMap[match.status]||match.status}}</view>
          <text wx:if="{{match.fee>0}}" class="fee-badge">¥{{match.fee}}</text>
          <text wx:else class="fee-badge fee-free">免费</text>
        </view>
        <view class="hero-meta">
          <view class="meta-item icon-row"><svg-icon name="map-pin" size="26" color="rgba(255,255,255,0.8)"/><text>{{match.location}}</text></view>
          <view wx:if="{{match.startTime}}" class="meta-item icon-row"><svg-icon name="clock" size="26" color="rgba(255,255,255,0.8)"/><text>{{match.startTime}}</text></view>
        </view>
      </view>
    </view>

    <!-- 统计栏：仅在报名/暂停状态显示 -->
    <view wx:if="{{match.status!=='ongoing'&&match.status!=='finished'}}" class="stat-bar">
      <view class="stat-item">
        <text class="stat-n">{{match.registeredCount}}</text>
        <text class="stat-l">已报名</text>
      </view>
      <view class="stat-sep"/>
      <view class="stat-item">
        <text class="stat-n">{{match.maxPlayers}}</text>
        <text class="stat-l">人数上限</text>
      </view>
      <view class="stat-sep"/>
      <view class="stat-item">
        <text class="stat-n">{{match.maxPlayers-match.registeredCount}}</text>
        <text class="stat-l">剩余名额</text>
      </view>
    </view>

    <!-- Tab 栏：仅在进行中/已结束时显示 -->
    <view wx:if="{{match.status==='ongoing'||match.status==='finished'}}" class="tab-bar">
      <view class="tab-item {{activeTab==='games'?'tab-active':''}}" bindtap="switchTab" data-tab="games">
        <text>场次记录</text>
        <view wx:if="{{activeTab==='games'}}" class="tab-line"/>
      </view>
      <view class="tab-item {{activeTab==='leaderboard'?'tab-active':''}}" bindtap="switchTab" data-tab="leaderboard">
        <text>积分排行</text>
        <view wx:if="{{activeTab==='leaderboard'}}" class="tab-line"/>
      </view>
    </view>

  </view><!-- /page-top -->

  <!-- 内容区 -->
  <view class="page-body" style="top:{{topHeight}}px">

    <!-- 报名状态：报名选手列表 -->
    <view wx:if="{{match.status!=='ongoing'&&match.status!=='finished'}}" class="card card-flex">
      <view class="card-hd">
        <text class="card-title">报名选手</text>
        <text class="card-count">{{match.registeredCount}}人</text>
      </view>
      <view wx:if="{{!match.players||!match.players.length}}" class="empty-players">
        <text>还没有人报名，快来第一个！</text>
      </view>
      <scroll-view wx:else class="players-scroll" scroll-y enable-passive>
        <view wx:for="{{match.players}}" wx:key="id" class="player-row">
          <view class="player-avatar">
            <image wx:if="{{item.avatar}}" src="{{item.avatar}}" class="av-img" mode="aspectFill"/>
            <svg-icon wx:else name="user" size="40" color="#aaa"/>
          </view>
          <view class="player-info">
            <text class="player-name">{{item.name}}</text>
            <text wx:if="{{item.level}}" class="player-level">{{item.level}}</text>
          </view>
          <view wx:if="{{isOrganizer}}" class="remove-btn" catchtap="adminRemove" data-reg-id="{{item.regId}}" data-name="{{item.name}}">
            <text>移除</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 进行中/已结束：tab 内容 -->
    <block wx:if="{{match.status==='ongoing'||match.status==='finished'}}">

      <!-- Tab: 场次记录 -->
      <view wx:if="{{activeTab==='games'}}" class="card card-flex">
        <view class="card-hd">
          <text class="card-title">场次记录</text>
          <text class="card-count">{{games.length}}场</text>
        </view>
        <view wx:if="{{!games.length}}" class="empty-players"><text>暂无场次</text></view>
        <scroll-view wx:else class="players-scroll" scroll-y enable-passive>
          <view wx:for="{{games}}" wx:key="id" class="game-card-item">
            <view class="game-card-no">第 {{index+1}} 场</view>
            <view class="game-card-body">
              <view class="game-side {{item.winnerTeam==='team1'?'side-win':item.status==='finished'?'side-lose':''}}">
                <view class="gs-players">
                  <text class="gs-player">{{item.player1.nickname}}</text>
                  <text wx:if="{{item.partner1}}" class="gs-player">{{item.partner1.nickname}}</text>
                </view>
                <view wx:if="{{isOrganizer&&match.status==='ongoing'}}" class="gs-score-wrap" catchtap="onScoreTap" data-game-id="{{item.id}}" data-team="1">
                  <input class="gs-score-input {{item.winnerTeam==='team1'?'score-win':''}}" type="number" value="{{item.score1!=null?item.score1:''}}" placeholder="-" data-game-id="{{item.id}}" data-team="1" bindblur="onScoreBlur" bindinput="onScoreInput" maxlength="3"/>
                </view>
                <text wx:else class="gs-score {{item.winnerTeam==='team1'?'score-win':''}}">{{item.status==='finished'?item.score1:'-'}}</text>
              </view>
              <view class="game-divider"><text class="game-vs-txt">VS</text></view>
              <view class="game-side game-side-r {{item.winnerTeam==='team2'?'side-win':item.status==='finished'?'side-lose':''}}">
                <view wx:if="{{isOrganizer&&match.status==='ongoing'}}" class="gs-score-wrap" catchtap="onScoreTap" data-game-id="{{item.id}}" data-team="2">
                  <input class="gs-score-input {{item.winnerTeam==='team2'?'score-win':''}}" type="number" value="{{item.score2!=null?item.score2:''}}" placeholder="-" data-game-id="{{item.id}}" data-team="2" bindblur="onScoreBlur" bindinput="onScoreInput" maxlength="3"/>
                </view>
                <text wx:else class="gs-score {{item.winnerTeam==='team2'?'score-win':''}}">{{item.status==='finished'?item.score2:'-'}}</text>
                <view class="gs-players gs-players-r">
                  <text class="gs-player">{{item.player2.nickname}}</text>
                  <text wx:if="{{item.partner2}}" class="gs-player">{{item.partner2.nickname}}</text>
                </view>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- Tab: 积分排行 -->
      <view wx:if="{{activeTab==='leaderboard'}}" class="card card-flex">
        <view class="card-hd">
          <text class="card-title">积分排行</text>
        </view>
        <view wx:if="{{!leaderboard.length}}" class="empty-players"><text>暂无数据</text></view>
        <scroll-view wx:else class="players-scroll" scroll-y enable-passive>
          <view class="lb-header">
            <text class="lb-rank">名次</text>
            <text class="lb-name">选手</text>
            <text class="lb-pts">积分</text>
            <text class="lb-wdl">胜/平/负</text>
          </view>
          <view wx:for="{{leaderboard}}" wx:key="id" class="lb-row {{index<3?'lb-top':''}}">
            <text wx:if="{{item.rank===1}}" class="lb-rank" style="color:#f59e0b;font-weight:700">1</text>
            <text wx:elif="{{item.rank===2}}" class="lb-rank" style="color:#9ca3af;font-weight:700">2</text>
            <text wx:elif="{{item.rank===3}}" class="lb-rank" style="color:#b45309;font-weight:700">3</text>
            <text wx:else class="lb-rank">{{item.rank}}</text>
            <text class="lb-name">{{item.name}}</text>
            <text class="lb-pts lb-pts-val">{{item.points}}</text>
            <text class="lb-wdl">{{item.wins}}/{{item.draws}}/{{item.losses}}</text>
          </view>

          <!-- 已结束横幅 -->
          <view wx:if="{{match.status==='finished'}}" class="finished-banner">
            <svg-icon name="sparkles" size="80" color="#f59e0b"/>
            <text class="fb-txt">比赛已结束，感谢参与！</text>
          </view>
        </scroll-view>
      </view>

    </block>

  </view><!-- /page-body -->

  <!-- 底部操作栏 -->
  <view wx:if="{{match}}" class="action-bar">
    <view class="share-btn" bindtap="shareMatch">
      <svg-icon name="share" size="36" color="#555"/>
      <text class="share-txt">分享</text>
    </view>
    <block wx:if="{{isOrganizer}}">
      <view wx:if="{{match.status==='open'}}" class="org-action-row">
        <view class="reg-btn reg-half" bindtap="doRegister">
          <text>{{registering?'处理中...':(isRegistered?'已报名':'我也报名')}}</text>
        </view>
        <view class="org-btn org-start" bindtap="openFormatSheet">
          <text>▶ 开始比赛</text>
        </view>
        <view class="org-btn org-pause" bindtap="pauseMatch">
          <text>暂停</text>
        </view>
      </view>
      <view wx:elif="{{match.status==='paused'}}" class="org-action-row">
        <view class="org-btn org-resume" bindtap="resumeMatch">
          <text>▶ 恢复报名</text>
        </view>
        <view class="org-btn org-cancel" bindtap="cancelMatch">
          <text>取消比赛</text>
        </view>
      </view>
      <view wx:elif="{{match.status==='ongoing'}}" class="org-action-row">
        <view class="org-btn org-restart" bindtap="openFormatSheet">
          <text>重新开始</text>
        </view>
        <view class="org-btn org-finish" bindtap="finishMatch">
          <text>结束比赛</text>
        </view>
      </view>
      <view wx:else class="org-action-row">
        <view class="reg-btn reg-disabled" style="flex:1">
          <text>{{match.status==='cancelled'?'已取消':'已完赛'}}</text>
        </view>
        <view wx:if="{{match.status==='cancelled'}}" class="org-btn org-delete" bindtap="deleteMatch">
          <text>彻底删除</text>
        </view>
      </view>
    </block>
    <block wx:else>
      <view wx:if="{{match.status==='open'}}"
        class="reg-btn {{isRegistered?'reg-cancel':''}} {{registering?'reg-loading':''}}"
        bindtap="doRegister">
        <text>{{registering?'处理中...':(isRegistered?'已报名（点击取消）':'立即报名')}}</text>
      </view>
      <view wx:else class="reg-btn reg-disabled">
        <text>{{match.status==='paused'?'报名已暂停':match.status==='ongoing'?'进行中':match.status==='cancelled'?'已取消':'已结束'}}</text>
      </view>
    </block>
  </view>

  <!-- 记分弹窗 -->
  <view wx:if="{{showScoreModal}}" class="sheet-mask" bindtap="closeScoreModal">
    <view class="sheet score-sheet" catchtap="">
      <view class="sheet-handle"/>
      <text class="sheet-title">录入比分</text>
      <view wx:if="{{editingGame}}" class="score-teams">
        <text class="st-name">{{editingGame.player1.nickname}}{{editingGame.partner1?' & '+editingGame.partner1.nickname:''}}</text>
        <text class="st-vs">VS</text>
        <text class="st-name">{{editingGame.player2.nickname}}{{editingGame.partner2?' & '+editingGame.partner2.nickname:''}}</text>
      </view>
      <view class="score-inputs">
        <input class="score-input" type="number" value="{{editScore1}}" bindinput="onScore1" placeholder="0" maxlength="3"/>
        <text class="score-colon">:</text>
        <input class="score-input" type="number" value="{{editScore2}}" bindinput="onScore2" placeholder="0" maxlength="3"/>
      </view>
      <view class="score-confirm-btn" bindtap="submitScore"><text>确认保存</text></view>
    </view>
  </view>



  <!-- 赛制选择弹窗 -->
  <view wx:if="{{showFormatSheet}}" class="sheet-mask" bindtap="closeFormatSheet">
    <view class="sheet" catchtap="">
      <view class="sheet-handle"/>
      <text class="sheet-title">选择赛制</text>
      <view wx:for="{{formats}}" wx:key="type" class="fmt-item {{item.enabled?'':'fmt-disabled'}}" bindtap="selectFormat" data-fmt="{{item}}">
        <view class="fmt-body">
          <text class="fmt-name">{{item.name}}</text>
          <text class="fmt-desc">{{item.desc}}</text>
        </view>
        <text wx:if="{{item.enabled}}" class="fmt-arrow">›</text>
        <view wx:else class="fmt-soon">即将上线</view>
      </view>
    </view>
  </view>

  </block><!-- /wx:elif match -->

  <login-sheet visible="{{showLogin}}" bindclose="hideLogin" bindsuccess="onLoginSuccess"/>
</view>
