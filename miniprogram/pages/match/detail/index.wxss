.page{background:#f0f2f5;padding-bottom:160rpx;min-height:100vh}

/* 加载 */
.loading{display:flex;align-items:center;justify-content:center;height:400rpx}

/* hero */
.hero{padding:48rpx 32rpx 40rpx;position:relative;overflow:hidden}
.hero-deco{position:absolute;font-size:240rpx;opacity:.07;right:-20rpx;top:0;line-height:1}
.hero-inner{position:relative;z-index:2}
.hero-top{display:flex;align-items:center;gap:12rpx;margin-bottom:16rpx}
.status-badge{font-size:22rpx;padding:6rpx 20rpx;border-radius:50rpx;font-weight:600}
.status-open{background:#e8f7ee;color:#1DB954}
.status-ongoing{background:#fff3e0;color:#f57c00}
.status-done,.status-finished{background:#f5f5f5;color:#999}
.status-draft{background:#e8eaf6;color:#5c6bc0}
.status-paused{background:#fff3e0;color:#f57c00}
.status-cancelled{background:#fce4ec;color:#e53935}
.fee-badge{font-size:22rpx;padding:6rpx 20rpx;border-radius:50rpx;background:rgba(255,255,255,.15);color:#fff;font-weight:600}
.fee-free{background:rgba(29,185,84,.2);color:#1DB954}
.hero-name{display:block;font-size:40rpx;font-weight:bold;color:#fff;line-height:1.4;margin-bottom:20rpx}
.hero-meta{display:flex;flex-direction:column;gap:8rpx}
.meta-item{font-size:26rpx;color:rgba(255,255,255,.7)}

/* 统计栏 */
.stat-bar{margin:0 24rpx;background:#fff;border-radius:24rpx;display:flex;padding:28rpx 0;box-shadow:0 4rpx 16rpx rgba(0,0,0,.06);transform:translateY(-20rpx)}
.stat-item{flex:1;text-align:center}
.stat-n{display:block;font-size:40rpx;font-weight:bold;color:#1a1a1a;margin-bottom:4rpx}
.stat-l{font-size:22rpx;color:#888}
.stat-sep{width:1rpx;background:#f0f0f0}

/* 卡片 */
.card{margin:0 24rpx 24rpx;background:#fff;border-radius:24rpx;padding:28rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.05)}
.card-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:20rpx}
.card-title{font-size:30rpx;font-weight:bold;color:#1a1a1a;margin-bottom:20rpx;display:block}
.card-hd .card-title{margin-bottom:0}
.card-count{font-size:24rpx;color:#888}

/* 信息行 */
.info-row{display:flex;gap:16rpx;padding:14rpx 0;border-bottom:1rpx solid #f8f8f8}
.info-row:last-child{border-bottom:none}
.info-icon{font-size:32rpx;width:40rpx;flex-shrink:0;margin-top:2rpx}
.info-body{flex:1}
.info-label{display:block;font-size:22rpx;color:#aaa;margin-bottom:4rpx}
.info-val{font-size:28rpx;color:#1a1a1a}
.desc{line-height:1.7;white-space:pre-wrap}

/* 报名列表 */
.empty-players{padding:32rpx 0;text-align:center;color:#bbb;font-size:26rpx}
.players-list{display:flex;flex-direction:column;gap:0}
.player-row{display:flex;align-items:center;gap:16rpx;padding:16rpx 0;border-bottom:1rpx solid #f5f5f5}
.player-row:last-child{border-bottom:none}
.player-avatar{width:72rpx;height:72rpx;background:#f0f2f5;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.pa-emoji{font-size:36rpx}
.player-info{flex:1}
.player-name{display:block;font-size:28rpx;color:#1a1a1a}
.player-level{font-size:22rpx;color:#aaa}
.remove-btn{padding:10rpx 24rpx;background:#fce4ec;border-radius:50rpx}
.remove-btn text{font-size:24rpx;color:#e53935}

/* 底部操作栏 */
.action-bar{position:fixed;bottom:0;left:0;right:0;background:#fff;padding:16rpx 24rpx 40rpx;display:flex;gap:16rpx;box-shadow:0 -4rpx 20rpx rgba(0,0,0,.08)}
.share-btn{width:96rpx;height:96rpx;border-radius:20rpx;background:#f5f5f5;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4rpx;flex-shrink:0;font-size:32rpx}
.share-txt{font-size:18rpx;color:#666}
.reg-btn{flex:1;height:96rpx;background:linear-gradient(135deg,#1a1a2e,#0f3460);border-radius:20rpx;display:flex;align-items:center;justify-content:center}
.reg-btn text{font-size:30rpx;font-weight:bold;color:#fff}
.reg-cancel{background:linear-gradient(135deg,#e8f7ee,#c8efd8)}
.reg-cancel text{color:#0a7a38}
.reg-loading{opacity:.6}
.reg-disabled{background:#f5f5f5}
.reg-disabled text{color:#aaa}
.org-action-row{flex:1;display:flex;gap:12rpx}
.reg-half{flex:1}
.org-btn{flex:1;height:96rpx;border-radius:20rpx;display:flex;align-items:center;justify-content:center}
.org-btn text{font-size:26rpx;font-weight:600}
.org-start{background:#e8f7ee}.org-start text{color:#0a7a38}
.org-restart{background:#e3f2fd}.org-restart text{color:#1565c0}
.org-finish{background:#fff8e1}.org-finish text{color:#f57f17}
.org-pause{background:#fff3e0}.org-pause text{color:#f57c00}
.org-resume{background:#e8f7ee}.org-resume text{color:#1DB954}
.org-cancel{background:#fce4ec}.org-cancel text{color:#e53935}
.org-delete{background:#fce4ec}.org-delete text{color:#e53935}

/* 场次卡片 */
.game-card-item{border-bottom:1rpx solid #f5f5f5;padding:20rpx 0}
.game-card-item:last-child{border-bottom:none}
.game-card-no{font-size:20rpx;color:#bbb;margin-bottom:12rpx}
.game-card-body{display:flex;align-items:stretch;gap:0;background:#f8f9fb;border-radius:16rpx;overflow:hidden}
.game-side{flex:1;display:flex;align-items:center;justify-content:space-between;padding:20rpx 20rpx;gap:12rpx}
.game-side-r{flex-direction:row-reverse}
.side-win{background:#e8f7ee}
.side-lose{background:#fafafa}
.gs-players{display:flex;flex-direction:column;gap:4rpx;flex:1}
.gs-players-r{align-items:flex-end}
.gs-player{font-size:26rpx;color:#1a1a1a;font-weight:500}
.gs-score{font-size:44rpx;font-weight:bold;color:#ccc;min-width:48rpx;text-align:center;flex-shrink:0}
.score-win{color:#0a7a38}
.game-divider{width:64rpx;display:flex;align-items:center;justify-content:center;background:#f0f2f5;flex-shrink:0}
.game-vs-txt{font-size:20rpx;color:#bbb;font-weight:bold}
.game-record-btn{margin-top:12rpx;display:flex;justify-content:flex-end}
.game-record-btn text{font-size:24rpx;color:#555;background:#f0f2f5;padding:10rpx 24rpx;border-radius:50rpx}

/* 排行榜 */
.lb-header{display:flex;align-items:center;padding:12rpx 0;border-bottom:2rpx solid #f0f2f5;margin-bottom:4rpx}
.lb-row{display:flex;align-items:center;padding:16rpx 0;border-bottom:1rpx solid #f9f9f9}
.lb-row.lb-top{background:linear-gradient(90deg,#fffbf0,transparent)}
.lb-rank{width:80rpx;font-size:26rpx;color:#888;text-align:center;flex-shrink:0}
.lb-name{flex:1;font-size:28rpx;color:#1a1a1a}
.lb-pts{width:80rpx;font-size:26rpx;color:#888;text-align:center;flex-shrink:0}
.lb-pts-val{font-size:32rpx;font-weight:bold;color:#0a7a38}
.lb-wdl{width:120rpx;font-size:22rpx;color:#aaa;text-align:center;flex-shrink:0}

/* 完赛横幅 */
.finished-banner{margin:16rpx 0 8rpx;background:linear-gradient(135deg,#1a1a2e,#0f3460);border-radius:24rpx;padding:32rpx;display:flex;align-items:center;justify-content:center;gap:16rpx}
.fb-emoji{font-size:40rpx}
.fb-txt{font-size:28rpx;color:#fff;font-weight:bold}

/* 记分弹窗 */
.score-sheet{padding-bottom:48rpx}
.score-teams{display:flex;align-items:center;justify-content:center;gap:16rpx;padding:16rpx 32rpx 24rpx}
.st-name{flex:1;font-size:26rpx;color:#333;text-align:center;line-height:1.5}
.st-vs{font-size:24rpx;color:#bbb;flex-shrink:0}
.score-inputs{display:flex;align-items:center;justify-content:center;gap:20rpx;padding:0 48rpx 32rpx}
.score-input{width:140rpx;height:100rpx;background:#f8f8f8;border-radius:20rpx;font-size:52rpx;font-weight:bold;color:#1a1a1a;text-align:center}
.gs-score-wrap{min-width:72rpx;display:flex;align-items:center;justify-content:center}
.gs-score-input{width:72rpx;height:60rpx;background:rgba(255,255,255,.6);border-radius:12rpx;font-size:32rpx;font-weight:bold;color:#1a1a1a;text-align:center;border:2rpx dashed #ccc}
.score-colon{font-size:52rpx;color:#ccc;font-weight:bold}
.score-confirm-btn{margin:0 32rpx;background:linear-gradient(135deg,#1a1a2e,#0f3460);border-radius:24rpx;height:88rpx;display:flex;align-items:center;justify-content:center}
.score-confirm-btn text{font-size:30rpx;font-weight:bold;color:#fff}

/* 赛制选择弹窗 */
.sheet{background:#fff;border-radius:32rpx 32rpx 0 0;width:100%;padding:0 0 60rpx}
.fmt-item{display:flex;align-items:center;padding:28rpx 32rpx;border-bottom:1rpx solid #f5f5f5}
.fmt-item:last-child{border-bottom:none}
.fmt-disabled{opacity:.4}
.fmt-body{flex:1}
.fmt-name{display:block;font-size:30rpx;font-weight:600;color:#1a1a1a;margin-bottom:6rpx}
.fmt-desc{font-size:24rpx;color:#aaa}
.fmt-arrow{font-size:36rpx;color:#ccc}
.fmt-soon{font-size:22rpx;color:#bbb;background:#f5f5f5;padding:6rpx 16rpx;border-radius:50rpx}
