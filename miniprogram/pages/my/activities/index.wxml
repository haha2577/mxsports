<view class="page">
  <view class="page-header" style="background:{{heroGrad}}">
    <nav-bar background="{{heroGrad}}" title="我的活动"/>
    <view class="hd-body">
      <text class="hd-sub">你参与和创建的所有比赛</text>
    </view>
    <view class="status-tabs">
      <view wx:for="{{tabs}}" wx:key="value" class="stab {{activeTab===item.value?'stab-a':''}}" bindtap="setTab" data-v="{{item.value}}">
        {{item.label}}
        <text wx:if="{{counts[item.value]}}" class="stab-count">{{counts[item.value]}}</text>
      </view>
    </view>
  </view>
  <scroll-view class="page-body" scroll-y enable-passive>
    <view wx:if="{{loading}}" class="empty"><text class="et">加载中...</text></view>
    <view wx:elif="{{!filteredList.length}}" class="empty">
      <svg-icon name="clipboard" size="80" color="#ddd"/><text class="et">还没有活动</text>
      <view class="empty-btn" bindtap="goCreate">创建第一个活动 →</view>
    </view>
    <view wx:else class="list">
      <view wx:for="{{filteredList}}" wx:key="id" class="activity-card" bindtap="goDetail" data-id="{{item.id}}">
        <view class="card-bar {{item.sport==='badminton'||!item.sport?'bar-b':'bar-t'}}"/>
        <view class="card-body">
          <view class="card-top">
            <text class="card-title">{{item.name}}</text>
            <view class="sp-badge sp-{{item.status}}">
              {{item.status==='open'?'报名中':item.status==='ongoing'?'进行中':item.status==='finished'?'已结束':'草稿'}}
            </view>
          </view>
          <view wx:if="{{item.location}}" class="ci icon-row"><svg-icon name="map-pin" size="26" color="#bbb"/><text>{{item.location}}</text></view>
          <view wx:if="{{item.startTime}}" class="ci icon-row"><svg-icon name="calendar" size="26" color="#bbb"/><text>{{item.startTime}}</text></view>
          <view class="card-tags">
            <view class="sport-tag {{item.sport==='tennis'?'tag-t':'tag-b'}}">{{item.sport==='tennis'?'网球':'羽毛球'}}</view>
            <view class="role-tag">{{item.role==='organizer'?'发起人':'参与者'}}</view>
          </view>
          <view wx:if="{{item.maxPlayers}}" class="card-footer">
            <view class="cf-p icon-row"><svg-icon name="users" size="26" color="#ccc"/><text>{{item.registeredCount||0}}/{{item.maxPlayers}} 人</text></view>
          </view>
        </view>
      </view>
    </view>
    <view class="safe-bottom"/>
  </scroll-view>
</view>
