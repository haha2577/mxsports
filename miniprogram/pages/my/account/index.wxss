.page{background:#f0f2f5}
.page-header{padding:0}

.card{margin:24rpx 24rpx 0;background:#fff;border-radius:24rpx;padding:28rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.05)}
.card-label{display:block;font-size:24rpx;color:#aaa;margin-bottom:20rpx}

/* 头像 */
.avatar-btn{padding:0;margin:0;background:none;border:none;line-height:normal;font-size:0;display:block;width:120rpx;height:120rpx}
.avatar-btn::after{display:none}
.avatar-wrap{position:relative;width:120rpx;height:120rpx}
.avatar-img{width:120rpx;height:120rpx;border-radius:50%}
.avatar-placeholder{width:120rpx;height:120rpx;background:#f0f2f5;border-radius:50%;display:flex;align-items:center;justify-content:center}
.ap-emoji{font-size:56rpx}
.avatar-edit-badge{position:absolute;bottom:0;right:0;width:40rpx;height:40rpx;background:#1a1a2e;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22rpx}

/* 昵称 */
.input-row{display:flex;align-items:center;gap:16rpx}
.nickname-input{flex:1;background:#f8f8f8;border-radius:16rpx;padding:0 24rpx;height:80rpx;line-height:80rpx;font-size:30rpx;color:#1a1a1a;box-sizing:border-box}
.save-btn{height:80rpx;padding:0 32rpx;background:#1a1a2e;border-radius:16rpx;flex-shrink:0;display:flex;align-items:center}
.save-btn text{font-size:26rpx;color:#fff;font-weight:bold}
.save-loading{opacity:.6}

/* 危险区 */
.danger-zone{margin:48rpx 24rpx 0}
.danger-btn{background:#fff;border-radius:24rpx;padding:28rpx 32rpx;display:flex;align-items:center;gap:16rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.05)}
.danger-icon{font-size:36rpx}
.danger-label{flex:1;font-size:28rpx;color:#e53935;font-weight:bold}
.danger-sub{font-size:22rpx;color:#aaa}
