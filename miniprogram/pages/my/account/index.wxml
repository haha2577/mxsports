<view class="page">

  <view class="page-header" style="background:{{heroGrad}}">
    <nav-bar background="{{heroGrad}}" title="账号设置"/>
    <view class="hd-body">
      <text class="hd-sub">管理你的个人信息</text>
    </view>
  </view>
  <scroll-view class="page-body" scroll-y enable-passive>

  <!-- 头像 -->
  <view class="card">
    <text class="card-label">头像</text>
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <view class="avatar-wrap">
        <image wx:if="{{avatar}}" class="avatar-img" src="{{avatar}}" mode="aspectFill"/>
        <view wx:else class="avatar-placeholder"><svg-icon name="user-circle" size="60" color="#ccc"/></view>
        <view class="avatar-edit-badge"><svg-icon name="camera" size="28" color="#fff"/></view>
      </view>
    </button>
  </view>

  <!-- 昵称 -->
  <view class="card">
    <text class="card-label">昵称</text>
    <view class="input-row">
      <input class="nickname-input" type="nickname" value="{{nickname}}" bindinput="onNickname"
        bindblur="onNicknameBlur" placeholder="输入你的昵称" maxlength="20"/>
      <view wx:if="{{nicknameChanged}}" class="save-btn {{saving?'save-loading':''}}" bindtap="saveNickname">
        <text>{{saving?'保存中':'保存'}}</text>
      </view>
    </view>
  </view>

  <!-- 手机号 -->
  <view class="card" bindtap="{{phone?'':'showBindPhone'}}">
    <text class="card-label">手机号</text>
    <view class="phone-row">
      <text class="phone-val {{phone?'':'phone-empty'}}">{{phone||'未绑定'}}</text>
      <text wx:if="{{!phone}}" class="bind-btn">绑定 ›</text>
    </view>
  </view>

  <!-- 绑定手机号弹窗 -->
  <view wx:if="{{showBindPhone}}" class="bind-mask" bindtap="hideBindPhone">
    <view class="bind-sheet" catchtap="">
      <text class="bind-title">绑定手机号</text>
      <view class="ls-input-wrap">
        <text class="ls-prefix">+86</text>
        <input class="ls-input" value="{{bindPhone}}" bindinput="onBindPhone" type="number" maxlength="11" placeholder="请输入手机号"/>
      </view>
      <view class="ls-input-wrap">
        <input class="ls-input" value="{{bindCode}}" bindinput="onBindCode" type="number" maxlength="6" placeholder="请输入验证码"/>
        <text class="ls-sms-btn {{bindCountdown>0?'ls-sms-cd':''}}" bindtap="sendBindCode">{{bindCountdown>0?bindCountdown+'s':'获取验证码'}}</text>
      </view>
      <text wx:if="{{bindError}}" class="ls-error">{{bindError}}</text>
      <view class="ls-btn ls-confirm {{!bindPhone||!bindCode?'ls-disabled':''}}" bindtap="doBindPhone">
        <text class="ls-btn-txt">{{bindLoading?'绑定中...':'确认绑定'}}</text>
      </view>
    </view>
  </view>

  <!-- 危险区域 -->
  <view class="danger-zone">
    <view class="danger-btn" bindtap="deleteAccount">
      <svg-icon name="alert-triangle" size="40" color="#e53935"/>
      <text class="danger-label">注销账号</text>
      <text class="danger-sub">删除所有数据，不可恢复</text>
    </view>
  </view>

    <view class="safe-bottom"/>
  </scroll-view>
</view>
