.page{background:#f0f2f5;min-height:100vh;padding-bottom:80rpx}
.page-header{padding:0}
.es{font-size:24rpx;color:#ccc;text-align:center}
.list{padding:24rpx}
.friend-card{background:#fff;border-radius:24rpx;padding:28rpx;display:flex;align-items:center;gap:20rpx;margin-bottom:16rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.05)}
.avatar{width:88rpx;height:88rpx;background:#f0f2f5;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.av-emoji{font-size:44rpx}
.info{flex:1;min-width:0}
.nickname{display:block;font-size:30rpx;font-weight:bold;color:#1a1a1a;margin-bottom:8rpx}
.last-match{display:flex;align-items:center;gap:8rpx;margin-bottom:6rpx}
.lm-label{font-size:20rpx;color:#fff;background:#1a1a2e;padding:2rpx 12rpx;border-radius:50rpx;flex-shrink:0}
.lm-name{font-size:26rpx;color:#333;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.lm-meta{display:flex;flex-wrap:wrap;gap:12rpx}
.lm-time,.lm-loc{font-size:22rpx;color:#aaa}
.arrow{font-size:36rpx;color:#ccc;flex-shrink:0}
