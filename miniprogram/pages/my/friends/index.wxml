<view class="page">

  <view class="page-header" style="background:{{heroGrad}}">
    <nav-bar background="{{heroGrad}}" title="我的球友"/>
    <view class="hd-body">
      <text class="hd-sub">一起参加过活动的伙伴</text>
    </view>
  </view>
  <scroll-view class="page-body" scroll-y enable-passive>

  <view wx:if="{{loading}}" class="empty"><text class="et">加载中...</text></view>

  <view wx:elif="{{!list.length}}" class="empty">
    <svg-icon name="users" size="80" color="#ddd"/>
    <text class="et">还没有球友</text>
    <text class="es">报名参加活动，认识更多球友吧！</text>
  </view>

  <view wx:else class="list">
    <view wx:for="{{list}}" wx:key="id" class="friend-card" bindtap="goMatch" data-id="{{item.lastMatch.id}}">
      <view class="avatar">
        <svg-icon name="user" size="48" color="#bbb"/>
      </view>
      <view class="info">
        <text class="nickname">{{item.nickname}}</text>
        <view class="last-match">
          <text class="lm-label">上次同场</text>
          <text class="lm-name">{{item.lastMatch.name}}</text>
        </view>
        <view class="lm-meta">
          <view wx:if="{{item.lastMatch.startTime}}" class="lm-time icon-row"><svg-icon name="clock" size="24" color="#bbb"/><text>{{item.lastMatch.startTime}}</text></view>
          <view wx:if="{{item.lastMatch.location}}" class="lm-loc icon-row"><svg-icon name="map-pin" size="24" color="#bbb"/><text>{{item.lastMatch.location}}</text></view>
        </view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

    <view class="safe-bottom"/>
  </scroll-view>
</view>
