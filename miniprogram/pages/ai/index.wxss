.page {
  height: 100vh;
  background: #f0f2f5;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ---- Header ---- */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}
.header-sub {
  display: flex;
  justify-content: flex-end;
  padding: 0 32rpx 16rpx;
}
.header-clear {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
}

/* ---- Chat body ---- */
.chat-body {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 120rpx;
  padding: 24rpx 24rpx 0;
}

/* ---- Welcome ---- */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 0;
}
.welcome-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.welcome-icon-text {
  font-size: 56rpx;
}
.welcome-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}
.welcome-desc {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 60rpx;
  text-align: center;
}
.login-hint {
  padding: 24rpx 64rpx;
  background: #fff;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.login-hint-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
.quick-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
}
.quick-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  padding: 24rpx 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  width: calc(50% - 10rpx);
  box-sizing: border-box;
}
.quick-icon {
  font-size: 36rpx;
}
.quick-text {
  font-size: 28rpx;
  color: #1a1a2e;
  font-weight: 500;
}

/* ---- Messages ---- */
.msg-wrap {
  display: flex;
  margin-bottom: 28rpx;
  align-items: flex-start;
}
.msg-user {
  flex-direction: row-reverse;
}
.msg-assistant {
  flex-direction: row;
}

/* ---- Avatars ---- */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.ai-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}
.ai-avatar-emoji {
  font-size: 36rpx;
}
.user-avatar {
  margin-left: 16rpx;
}
.user-avatar-default {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}
.user-avatar-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.bubble {
  max-width: 70%;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  word-break: break-all;
  line-height: 1.6;
}
.bubble-user {
  background: #fff;
  color: #1a1a1a;
  border-top-right-radius: 6rpx;
  font-size: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.bubble-assistant {
  background: #fff;
  color: #1a1a1a;
  border-top-left-radius: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  font-size: 30rpx;
}
.bubble-text {
  white-space: pre-wrap;
  word-wrap: break-word;
}

/* ---- Typing animation ---- */
.typing {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 0;
}
.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}
.d1 { animation-delay: -0.32s; }
.d2 { animation-delay: -0.16s; }
.d3 { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.5); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* ---- Bottom spacer ---- */
.bottom-spacer {
  height: 20rpx;
}

/* ---- Input bar ---- */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f0f2f5;
  border-radius: 44rpx;
  padding: 8rpx 8rpx 8rpx 32rpx;
}
.chat-input {
  flex: 1;
  height: 72rpx;
  font-size: 30rpx;
  color: #1a1a1a;
}
.input-ph {
  color: #bbb;
}
.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}
.send-arrow {
  font-size: 32rpx;
  color: #fff;
  transform: rotate(0deg);
}
