<view class="page">
  <!-- 顶部导航 -->
  <view class="header" style="background:{{heroGrad}}">
    <nav-bar title="AI 助手" back="{{false}}" background="{{heroGrad}}" bindheight="onNavHeight">
      <view slot="left" wx:if="{{messages.length}}" class="clear-btn" bindtap="onClearChat">
        <image class="clear-icon" src="/images/clear.svg" mode="aspectFit"/>
      </view>
    </nav-bar>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="chat-body"
    scroll-y
    scroll-into-view="{{scrollId}}"
    scroll-with-animation
    enable-passive
    show-scrollbar="{{false}}"
    style="top:{{navHeight + 40}}px"
  >
    <!-- 欢迎界面 -->
    <view wx:if="{{!messages.length}}" class="welcome">
      <view class="welcome-icon" style="background:{{heroGrad}}">
        <text class="welcome-icon-text">{{sportEmoji}}</text>
      </view>
      <text class="welcome-title">Hi，我是你的运动AI助手</text>
      <text class="welcome-desc">有什么关于羽毛球、网球的问题，都可以问我！</text>
      <view wx:if="{{!token}}" class="login-hint" bindtap="showLoginSheet">
        <text class="login-hint-text">登录后开始对话 ›</text>
      </view>
      <view wx:else class="quick-list">
        <view
          wx:for="{{quickQuestions}}" wx:key="text"
          class="quick-btn"
          bindtap="onQuickTap"
          data-text="{{item.text}}"
        >
          <text class="quick-icon">{{item.icon}}</text>
          <text class="quick-text">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- 消息气泡 -->
    <view wx:for="{{messages}}" wx:key="id" id="{{item.id}}" class="msg-wrap msg-{{item.role}}">
      <!-- AI 头像 -->
      <view wx:if="{{item.role === 'assistant'}}" class="avatar ai-avatar" style="background:{{heroGrad}}">
        <text class="ai-avatar-emoji">{{sportEmoji}}</text>
      </view>

      <!-- 用户头像 -->
      <image wx:if="{{item.role === 'user' && userAvatar}}" class="avatar user-avatar" src="{{userAvatar}}" mode="aspectFill"/>
      <view wx:if="{{item.role === 'user' && !userAvatar}}" class="avatar user-avatar-default" style="background:{{heroGrad}}">
        <text class="user-avatar-text">我</text>
      </view>

      <view class="bubble bubble-{{item.role}}" style="{{item.role === 'user' ? 'background:' + heroGrad : ''}}" bindlongpress="onCopyMsg" data-content="{{item.content}}">
        <!-- 打字动画 -->
        <view wx:if="{{item.loading}}" class="typing">
          <view class="dot d1" style="background:{{sportPrimary}}"/>
          <view class="dot d2" style="background:{{sportPrimary}}"/>
          <view class="dot d3" style="background:{{sportPrimary}}"/>
        </view>
        <block wx:elif="{{item.role === 'assistant'}}">
          <rich-text class="bubble-text md-body" nodes="{{item.nodes}}"/>
        </block>
        <text wx:else class="bubble-text" user-select>{{item.content}}</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"/>
  </scroll-view>

  <!-- 输入区 -->
  <view class="input-bar">
    <view class="input-wrap">
      <input
        class="chat-input"
        value="{{inputText}}"
        placeholder="{{token ? '问点什么...' : '请先登录'}}"
        placeholder-class="input-ph"
        confirm-type="send"
        disabled="{{!token}}"
        bindinput="onInput"
        bindconfirm="onSend"
        adjust-position="{{true}}"
        cursor-spacing="20"
      />
      <view class="send-btn {{inputText && !sending ? 'active' : ''}}" style="{{inputText && !sending ? 'background:' + heroGrad : ''}}" bindtap="onSend">
        <text class="send-arrow">➤</text>
      </view>
    </view>
  </view>

  <login-sheet visible="{{showLogin}}" bindclose="hideLogin" bindsuccess="onLoginSuccess"/>
</view>
