<view class="page">
  <view class="hero" style="padding-top:{{sbh+12}}px;background:{{heroGrad}}">
    <text class="hero-deco">{{activeSport==='badminton'?'🏸':'🎾'}}</text>
    <view class="hero-row">
      <view class="avatar-wrap"><text class="av-emoji">🏅</text></view>
      <view class="hero-info">
        <text class="username">{{token?nickname:'未登录'}}</text>
        <text wx:if="{{token&&phone}}" class="phone-txt">{{phone}}</text>
        <text wx:elif="{{!token}}" class="phone-sub" bindtap="showLoginSheet">点击登录 ›</text>
      </view>
      <sport-switcher wx:if="{{token}}" sport-pref="{{sportPref}}" active="{{activeSport}}" bindswitch="onSwitchSport"/>
    </view>
    <view wx:if="{{token}}" class="stat-row">
      <view class="stat-col"><text class="stat-n">{{stats.matches}}</text><text class="stat-l">参赛场次</text></view>
      <view class="stat-sep"/><view class="stat-col"><text class="stat-n">{{stats.wins}}</text><text class="stat-l">胜场</text></view>
      <view class="stat-sep"/><view class="stat-col"><text class="stat-n">{{stats.rate}}</text><text class="stat-l">胜率</text></view>
      <view class="stat-sep"/><view class="stat-col"><text class="stat-n">{{stats.points}}</text><text class="stat-l">积分</text></view>
    </view>
    <view wx:else class="login-hint" bindtap="showLoginSheet"><text class="lh-txt">登录后查看你的赛事数据 ›</text></view>
  </view>

  <view class="racket-banner" bindtap="goRacket">
    <view class="rb-body">
      <text class="rb-emoji">{{activeSport==='badminton'?'🏸':'🎾'}}</text>
      <view class="rb-text">
        <text class="rb-title">智能球拍推荐</text>
        <text class="rb-sub">根据你的数据精准匹配球拍</text>
      </view>
    </view>
    <text class="rb-arrow">›</text>
  </view>

  <view wx:if="{{token}}" class="section-card">
    <text class="sec-title">{{activeSport==='badminton'?'🏸 羽毛球':'🎾 网球'}}</text>
    <view class="menu-item" bindtap="goActivities">
      <view class="mi-l"><text class="mi-icon">🏅</text><text class="mi-label">我的活动</text></view>
      <text class="mi-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goVideo">
      <view class="mi-l"><text class="mi-icon">🎬</text><text class="mi-label">我的视频</text></view>
      <view style="display:flex;align-items:center;gap:8rpx">
        <text style="font-size:22rpx;color:#1DB954;background:#e8f7ee;padding:4rpx 14rpx;border-radius:50rpx">智能剪辑·AI评价</text>
        <text class="mi-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <text class="sec-title">设置</text>
    <view wx:if="{{token}}" class="menu-item" bindtap="showPrefSheet">
      <view class="mi-l"><text class="mi-icon">🏅</text><text class="mi-label">爱好选择</text></view>
      <view style="display:flex;align-items:center;gap:8rpx">
        <text class="mi-val">{{prefLabel}}</text>
        <text class="mi-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="goSettings">
      <view class="mi-l"><text class="mi-icon">⚙️</text><text class="mi-label">账号设置</text></view>
      <text class="mi-arrow">›</text>
    </view>
  </view>

  <button wx:if="{{token}}" class="logout-btn" bindtap="logout">退出登录</button>
  <text class="version-txt">v{{version}}</text>

  <login-sheet visible="{{showLogin}}" bindclose="hideLogin" bindsuccess="onLoginSuccess"/>
  <sport-pref-sheet visible="{{showSportPref}}" bindconfirm="onSportPrefConfirm"/>
</view>