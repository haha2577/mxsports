.page{background:#f0f2f5;padding-bottom:120rpx}
.header-unlogged{background:#fff;display:flex;justify-content:space-between;align-items:center;padding:0 40rpx 20rpx}
.app-name{font-size:34rpx;font-weight:bold;color:#1a1a1a}
.hero-unlogged{background:#1a1a2e;padding:48rpx 40rpx 36rpx;text-align:center}
.hu-title{display:block;font-size:44rpx;font-weight:bold;color:#fff;margin-bottom:10rpx}
.hu-sub{font-size:26rpx;color:rgba(255,255,255,.55)}
.sport-cards{display:flex;gap:20rpx;padding:24rpx 24rpx 0}
.sport-card{flex:1;border-radius:28rpx;padding:40rpx 28rpx;position:relative;overflow:hidden;box-shadow:0 10rpx 36rpx rgba(0,0,0,.14)}
.badminton-card{background:linear-gradient(145deg,#0faa4e,#1DB954,#25d366)}
.tennis-card{background:linear-gradient(145deg,#b5451b,#d4541f,#e8712a)}
.sc-emoji{display:block;font-size:72rpx;margin-bottom:12rpx}
.sc-name{display:block;font-size:40rpx;font-weight:bold;color:#fff;margin-bottom:8rpx}
.sc-desc{display:block;font-size:22rpx;color:rgba(255,255,255,.75);margin-bottom:28rpx}
.sc-btn{display:inline-flex;background:rgba(255,255,255,.92);border-radius:50rpx;padding:14rpx 32rpx}
.sc-btn-t{}
.sc-btn-txt{color:#1DB954;font-size:26rpx;font-weight:bold}
.sc-btn-txt-t{color:#d4541f}
.guest-login-row{margin:20rpx 24rpx 0;background:#fff;border-radius:20rpx;padding:28rpx;text-align:center;box-shadow:0 4rpx 16rpx rgba(0,0,0,.05)}
.gli-txt{font-size:28rpx;color:#555}
.hero{padding:0 32rpx 40rpx;position:relative;overflow:hidden}
.hero-deco{position:absolute;font-size:200rpx;opacity:.08;right:-20rpx;top:10rpx;line-height:1}
.hero-topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:28rpx;position:relative;z-index:2}
.avatar-btn{width:72rpx;height:72rpx;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;border:2rpx solid rgba(255,255,255,.25)}
.av-emoji{font-size:40rpx}
.hero-inner{position:relative;z-index:2}
.hero-greeting{display:block;font-size:28rpx;color:rgba(255,255,255,.8);margin-bottom:8rpx}
.hero-title{display:block;font-size:48rpx;font-weight:bold;color:#fff;margin-bottom:10rpx}
.hero-sub{display:block;font-size:26rpx;color:rgba(255,255,255,.8)}
.action-row{display:flex;gap:20rpx;padding:24rpx 24rpx 0}
.action-card{flex:1;background:#fff;border-radius:24rpx;padding:30rpx 16rpx;display:flex;flex-direction:column;align-items:center;box-shadow:0 4rpx 20rpx rgba(0,0,0,.06)}
.ac-icon{width:96rpx;height:96rpx;border-radius:24rpx;display:flex;align-items:center;justify-content:center;font-size:48rpx;margin-bottom:16rpx}
.ac-title{font-size:28rpx;font-weight:bold;color:#1a1a1a}
.section{margin:24rpx 24rpx 0;background:#fff;border-radius:24rpx;padding:28rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.05)}
.sec-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx}
.sec-hd-l{display:flex;align-items:center;gap:12rpx}
.dot{width:8rpx;height:36rpx;border-radius:4rpx}
.sec-title{font-size:32rpx;font-weight:bold;color:#1a1a1a}
.sec-more{font-size:26rpx}
.news-scroll{margin:0 -28rpx;padding:0 28rpx 8rpx}
.news-row{display:flex;gap:16rpx;padding-right:28rpx}
.news-card{width:260rpx;flex-shrink:0;background:#f8f8f8;border-radius:20rpx;overflow:hidden}
.news-cover{height:160rpx;display:flex;align-items:center;justify-content:center}
.nc-icon{font-size:72rpx}
.nc-cat{display:block;font-size:20rpx;padding:4rpx 14rpx;border-radius:50rpx;margin:12rpx 12rpx 6rpx;font-weight:500}
.nc-title{display:block;font-size:26rpx;font-weight:bold;color:#1a1a1a;padding:0 12rpx;margin-bottom:8rpx;line-height:1.5;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.nc-date{display:block;font-size:20rpx;color:#bbb;padding:0 12rpx 16rpx}
.match-item{display:flex;align-items:center;gap:16rpx;padding:20rpx 0;border-bottom:1rpx solid #f5f5f5}
.match-item:last-child{border-bottom:none}
.mi-icon{width:60rpx;height:60rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;font-size:30rpx}
.mi-body{flex:1}
.mi-name{display:block;font-size:30rpx;font-weight:bold;color:#1a1a1a;margin-bottom:6rpx}
.mi-info{font-size:22rpx;color:#888}
.mi-badge{font-size:22rpx;padding:8rpx 18rpx;border-radius:50rpx}
.s-open{background:#e8f7ee;color:#1DB954}.s-full{background:#f5f5f5;color:#999}.s-finished{background:#f5f5f5;color:#bbb}
.empty{text-align:center;padding:40rpx 0;color:#aaa;font-size:28rpx}