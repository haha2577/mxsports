<view class="page">
  <view class="page-header hero-logged" style="background:{{heroGrad}}">
    <nav-bar back="{{false}}" background="{{heroGrad}}"/>
    <text class="hero-deco">{{sportEmoji}}</text>
    <view class="hero-topbar">
      <sport-switcher can-switch="{{true}}" active="{{activeSport}}" bindswitch="onSwitchSport"/>
    </view>
    <view class="hero-inner">
      <text wx:if="{{token}}" class="hero-greeting">Hi，{{nickname}} 👋</text>
      <text wx:else class="hero-greeting" bindtap="showLoginSheet">登录 / 注册 ›</text>
      <text class="hero-sub">{{sportHeroSub}}</text>
    </view>
  </view>

  <scroll-view class="page-body" scroll-y enable-passive>
    <!-- 功能入口 -->
    <view class="action-row">
      <view class="action-card" bindtap="goCreate">
        <view class="ac-icon" style="background:{{sportCardBg}}"><svg-icon name="trophy" size="48" color="{{sportPrimary}}"/></view>
        <text class="ac-title">创建比赛</text>
      </view>
      <view wx:if="{{showVenueEntry}}" class="action-card" bindtap="goVenue">
        <view class="ac-icon" style="background:#e8f0fd"><svg-icon name="building" size="48" color="#5b85d0"/></view>
        <text class="ac-title">附近场馆</text>
      </view>
      <view class="action-card" bindtap="goNews">
        <view class="ac-icon" style="background:#fff0e0"><svg-icon name="newspaper" size="48" color="#e07b30"/></view>
        <text class="ac-title">最新资讯</text>
      </view>
    </view>

    <!-- 进行中的比赛 -->
    <view wx:if="{{ongoingMatches.length}}" class="section">
      <view class="sec-hd">
        <view class="sec-hd-l"><view class="dot dot-live"/><text class="sec-title">进行中的比赛</text></view>
        <text class="sec-more" bindtap="goActivities">我的比赛 ›</text>
      </view>
      <view wx:for="{{ongoingMatches}}" wx:key="id" class="ongoing-card" bindtap="goMatchDetail" data-id="{{item.id}}">
        <view class="oc-left">
          <view class="oc-live-dot"/>
          <view class="oc-info">
            <text class="oc-name">{{item.name}}</text>
            <view class="oc-meta icon-row"><svg-icon name="map-pin" size="24" color="#bbb"/><text>{{item.location}}</text></view>
          </view>
        </view>
        <view class="oc-right">
          <view class="oc-role {{item.role==='organizer'?'role-org':'role-player'}}">
            <text>{{item.role==='organizer'?'我创建':'我报名'}}</text>
          </view>
          <text class="oc-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 附近比赛 -->
    <view class="section">
      <view class="sec-hd">
        <view class="sec-hd-l"><view class="dot" style="background:{{sportPrimary}}"/><text class="sec-title">附近的比赛</text></view>
        <text class="sec-more" style="color:{{sportPrimary}}" bindtap="goMatchList">全部 ›</text>
      </view>
      <view wx:if="{{matches.length===0}}" class="empty">附近暂无比赛</view>
      <view wx:for="{{matches}}" wx:key="id" class="match-item" bindtap="goMatchDetail" data-id="{{item.id}}">
        <view class="mi-icon" style="background:{{sportListIconBg}}">
          <svg-icon name="award" size="32" color="{{sportPrimary}}"/>
        </view>
        <view class="mi-body">
          <text class="mi-name">{{item.name}}</text>
          <view class="mi-info icon-row"><svg-icon name="map-pin" size="24" color="#aaa"/><text>{{item.location}}{{item.startTime?' · '+item.startTime:''}}</text></view>
        </view>
        <text class="mi-badge s-{{item.status}}">{{item.status==='open'?'报名中':item.status==='full'?'已满员':'已结束'}}</text>
      </view>
    </view>
    <view class="safe-bottom-tabbar"/>
  </scroll-view>

  <login-sheet visible="{{showLogin}}" bindclose="hideLogin" bindsuccess="onLoginSuccess"/>
  <sport-pref-sheet visible="{{showSportPref}}" bindconfirm="onSportPrefConfirm"/>
</view>
