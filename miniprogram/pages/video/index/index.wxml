<view class="page">
  <view class="page-header" style="background:{{heroGrad}}">
    <nav-bar title="我的视频" background="{{heroGrad}}"/>
    <view class="hd-top">
      <view class="upload-btn" bindtap="chooseVideo"><text class="ui">＋</text><text class="ut">上传</text></view>
    </view>
  </view>
  <view class="page-body">
  <view wx:if="{{!videos.length}}" class="empty">
    <text class="ei">🎬</text><text class="et">还没有视频</text>
    <text class="es">上传你的打球视频，解锁智能剪辑和 AI 评价</text>
    <view class="empty-btn" bindtap="chooseVideo">上传第一个视频</view>
  </view>
  <view wx:else class="list">
    <view wx:for="{{videos}}" wx:key="id" class="video-card" bindtap="openVideo" data-id="{{item.id}}">
      <view class="thumb-wrap">
        <view class="thumb-ph"><text style="font-size:80rpx;opacity:.4">{{item.sport==='badminton'?'🏸':'🎾'}}</text></view>
        <view class="dur-tag">{{item.duration}}</view>
        <view wx:if="{{item.status!=='done'}}" class="st-badge st-{{item.status}}">{{item.status==='processing'?'AI处理中':'上传中'}}</view>
        <view wx:else class="play-btn">▶</view>
      </view>
      <view class="card-body">
        <text class="card-title">{{item.title}}</text>
        <view class="card-meta"><text class="meta-s">{{item.sport==='badminton'?'🏸 羽毛球':'🎾 网球'}}</text><text class="meta-d">{{item.date}}</text></view>
        <view wx:if="{{item.status==='done'}}" class="card-actions">
          <view class="ac ai-clip" catchtap="doClip" data-id="{{item.id}}"><text>✂️</text><text class="ac-t">智能剪辑</text></view>
          <view class="ac ai-eval" catchtap="doEval" data-id="{{item.id}}"><text>🤖</text><text class="ac-t">AI 评价</text></view>
          <view class="ac share-c"  catchtap="doShare"><text>📤</text><text class="ac-t">分享</text></view>
        </view>
        <view wx:elif="{{item.status==='processing'}}" class="proc-bar"><view class="proc-fill" style="width:{{item.progress}}%"/></view>
      </view>
    </view>
  </view>
  </view>
</view>