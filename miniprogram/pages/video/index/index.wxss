.page{background:#f0f2f5;padding-bottom:40rpx}
.page-header{padding:0 32rpx 24rpx}
.hd-top{display:flex;justify-content:space-between;align-items:center}
.upload-btn{display:flex;align-items:center;gap:8rpx;background:rgba(255,255,255,.15);border:1rpx solid rgba(255,255,255,.25);border-radius:50rpx;padding:14rpx 28rpx}
.ui{font-size:36rpx;color:#fff;line-height:1}.ut{font-size:26rpx;color:#fff;font-weight:500}
.es{font-size:26rpx;color:#999;text-align:center;margin-bottom:48rpx}
.empty-btn{background:#1a1a2e;color:#fff;font-size:30rpx;padding:24rpx 60rpx;border-radius:50rpx}
.list{padding:20rpx 24rpx;display:flex;flex-direction:column;gap:20rpx}
.video-card{background:#fff;border-radius:24rpx;overflow:hidden;box-shadow:0 4rpx 16rpx rgba(0,0,0,.07)}
.thumb-wrap{position:relative;height:300rpx;background:#1a1a2e}
.thumb-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(145deg,#1a1a2e,#0f3460)}
.dur-tag{position:absolute;bottom:12rpx;right:12rpx;background:rgba(0,0,0,.6);color:#fff;font-size:22rpx;padding:6rpx 16rpx;border-radius:8rpx}
.st-badge{position:absolute;top:12rpx;left:12rpx;font-size:22rpx;padding:6rpx 18rpx;border-radius:50rpx;font-weight:500}
.st-processing{background:#d1ecf1;color:#0c5460}
.play-btn{position:absolute;top:0;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:center;font-size:80rpx;color:rgba(255,255,255,.85)}
.card-body{padding:24rpx 28rpx}
.card-title{display:block;font-size:32rpx;font-weight:bold;color:#1a1a1a;margin-bottom:10rpx}
.card-meta{display:flex;gap:20rpx;margin-bottom:20rpx}
.meta-s,.meta-d{font-size:22rpx;color:#888}
.card-actions{display:flex;gap:12rpx;flex-wrap:wrap}
.ac{display:flex;align-items:center;gap:8rpx;padding:12rpx 22rpx;border-radius:50rpx;font-size:26rpx}
.ai-clip{background:#e8f4fd}.ai-eval{background:#f0e8fd}.share-c{background:#e8f7ee}
.ac-t{font-size:24rpx;color:#333;font-weight:500}
.proc-bar{height:8rpx;background:#f0f0f0;border-radius:4rpx;overflow:hidden}
.proc-fill{height:100%;background:linear-gradient(90deg,#1a1a2e,#0f3460);border-radius:4rpx}