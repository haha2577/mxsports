.page{background:#fff;min-height:100vh}
.page-header{padding:0}
.article{padding:32rpx}
.cat-badge{display:inline-block;font-size:22rpx;padding:6rpx 20rpx;border-radius:50rpx;font-weight:600;margin-bottom:16rpx}
.article-title{display:block;font-size:36rpx;font-weight:bold;color:#1a1a1a;line-height:1.5;margin-bottom:20rpx}
.article-meta{display:flex;align-items:center;gap:20rpx;flex-wrap:wrap;margin-bottom:32rpx;padding-bottom:24rpx;border-bottom:1rpx solid #f0f0f0}
.meta-sport,.meta-city,.meta-date{font-size:24rpx;color:#999}
.article-body{margin-bottom:32rpx}
.article-content{font-size:30rpx;color:#333;line-height:2}
.source-bar{background:#f8f9fb;border-radius:16rpx;padding:24rpx;margin-top:16rpx}
.source-label{font-size:24rpx;color:#888;display:block;margin-bottom:8rpx}
.source-url{font-size:22rpx;color:#1565c0;word-break:break-all;display:block}
