<view class="page">
  <view class="page-header" style="background:{{heroGrad}}">
    <nav-bar background="{{heroGrad}}" title="最新资讯"/>
    <view class="hd-body">
      <text class="hd-sub">球圈动态、赛事新闻、技术分享</text>
    </view>
    <scroll-view scroll-x class="cat-scroll">
      <view class="cat-row">
        <view wx:for="{{cats}}" wx:key="*this" class="cat-tag {{activeCat===item?'cat-a':''}}" bindtap="setCat" data-cat="{{item}}">{{item}}</view>
      </view>
    </scroll-view>
  </view>
  <scroll-view class="page-body" scroll-y enable-passive>
    <view wx:if="{{loading}}" class="empty"><text>加载中...</text></view>
    <view wx:elif="{{!list.length}}" class="empty"><text class="ei">📰</text><text>暂无资讯</text></view>
    <view wx:else class="list">
      <view wx:for="{{list}}" wx:key="id" class="news-item" bindtap="goDetail" data-id="{{item.id}}">
        <view class="ni-cover" style="background:{{item.category==='international'?'#1DB95415':item.category==='national'?'#1565c015':'#f57c0015'}}">
          <text class="ni-icon">{{item.category==='international'?'🌍':item.category==='national'?'🏆':'📍'}}</text>
        </view>
        <view class="ni-body">
          <text class="ni-cat" style="color:{{item.category==='international'?'#1DB954':item.category==='national'?'#1565c0':'#f57c00'}};background:{{item.category==='international'?'#1DB95415':item.category==='national'?'#1565c015':'#f57c0015'}}">{{item.categoryLabel}}</text>
          <text class="ni-title">{{item.title}}</text>
          <text class="ni-summary" wx:if="{{item.summary}}">{{item.summary}}</text>
          <text class="ni-date">{{item.publishedAt}}</text>
        </view>
      </view>
    </view>
    <view class="safe-bottom"/>
  </scroll-view>
</view>
